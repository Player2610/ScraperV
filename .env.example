# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker container (read/write for dev)
# For docker-compose: postgres://postgres:password@localhost:5432/protou?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/protou?sslmode=disable

# Production Neon DB — source for db-sync (READ ONLY)
# Copy the Neon connection string here. NEVER use this in application code.
# Data only flows: prod → dev. Never dev → prod.
PROD_DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>?sslmode=require

# ─── Auth ──────────────────────────────────────────────────────────────────────
# JWT secret — must be at least 32 characters of random data
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-min-32-characters-long-replace-me

# ─── External APIs ─────────────────────────────────────────────────────────────
# Resend API key for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Google Maps API key for geocoding
# Enable: Geocoding API in Google Cloud Console
GOOGLE_MAPS_API_KEY=

# ─── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on (default: 8080)
PORT=8080

# CORS origin — the Cloudflare Pages URL of the frontend
# For local dev: http://localhost:4321
CORS_ORIGIN=http://localhost:4321

# ─── Notifications ─────────────────────────────────────────────────────────────
# Email From header — use "protou DEV <pedidos+dev@protou.co>" in dev
# so dev emails son distinguibles de prod
NOTIFICATIONS_FROM=protou DEV <pedidos+dev@protou.co>

# Scraper alert recipient — leave blank to disable scraper email alerts
ALERT_EMAIL=

# ─── Operator Panel ────────────────────────────────────────────────────────────
# Test operator credentials (seeded by db/migrations/008_seed_operator.sql)
# email: operator@protou.co
# password: operator123
# Change the password in production via a secure mechanism.
