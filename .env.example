# ─── Development ───────────────────────────────────────────────────────────────

# Local Docker container (read/write)
# For docker-compose the container is reachable at localhost:5432
DATABASE_URL=postgres://postgres:password@localhost:5432/protou?sslmode=disable

# Port the API server listens on
PORT=8080

# CORS origin — frontend dev server (Astro default: 4321)
CORS_ORIGIN=http://localhost:4321

# Email From header — "DEV" suffix makes dev emails distinguishable from prod
NOTIFICATIONS_FROM=protou DEV <pedidos+dev@protou.co>

# Scraper alert recipient — leave blank to disable
ALERT_EMAIL=

# ─── Auth ──────────────────────────────────────────────────────────────────────

# JWT secret — minimum 32 random characters
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-min-32-characters-long-replace-me

# ─── Production credentials ────────────────────────────────────────────────────

# Neon production DB — READ ONLY. Used only by db-sync to pull data into local dev.
# Direction is always prod → dev. Never use this in application code.
# Get from: Neon console → your project → Connection string
PROD_DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>?sslmode=require

# Resend API key for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Google Maps API key for geocoding (Geocoding API must be enabled)
GOOGLE_MAPS_API_KEY=

# ─── Operator credentials (reference only) ─────────────────────────────────────
# Seeded by db/migrations/008_seed_operator.sql
# email: operator@protou.co / password: operator123
# Change the password in production via a secure mechanism.
