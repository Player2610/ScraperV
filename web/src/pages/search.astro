---
import Layout from "@/layouts/Layout.astro";
import { searchListings } from "@/lib/api";
import type { Listing } from "@/lib/api";

const url = Astro.url;
const q = url.searchParams.get("q") ?? "";
const categoryId = url.searchParams.get("category_id") ?? undefined;
const storeId = url.searchParams.get("store_id") ?? undefined;
const pageParam = parseInt(url.searchParams.get("page") ?? "1", 10);
const page = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const perPage = 20;

let listings: Listing[] = [];
let total = 0;
let fetchError = false;

try {
  const res = await searchListings({
    q: q || undefined,
    category: categoryId,
    store: storeId,
    page,
    per_page: perPage,
  });
  listings = res.listings;
  total = res.total;
} catch {
  fetchError = true;
}

const totalPages = Math.ceil(total / perPage);

function timeSince(isoDate: string | null): string {
  if (!isoDate) return "Hace un tiempo";
  const diff = Date.now() - new Date(isoDate).getTime();
  const hours = Math.floor(diff / 3_600_000);
  if (hours < 1) return "Hace menos de 1 hora";
  if (hours === 1) return "Hace 1 hora";
  if (hours < 24) return `Hace ${hours} horas`;
  const days = Math.floor(hours / 24);
  if (days === 1) return "Hace 1 día";
  return `Hace ${days} días`;
}

function isStale(isoDate: string | null): boolean {
  if (!isoDate) return false;
  const diff = Date.now() - new Date(isoDate).getTime();
  return diff > 24 * 3_600_000;
}

function buildPageUrl(p: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set("page", String(p));
  return `/search?${params.toString()}`;
}
---

<Layout title={q ? `Resultados para "${q}"` : "Catálogo"}>
  <!-- Search bar -->
  <form method="get" action="/search" class="flex gap-2 mb-8">
    <input
      type="text"
      name="q"
      value={q}
      placeholder="Busca resistencias, ESP32, sensores..."
      class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
    />
    <button
      type="submit"
      class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow hover:bg-indigo-700 whitespace-nowrap"
    >
      Buscar
    </button>
  </form>

  {
    fetchError && (
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700 mb-6">
        Error al cargar los resultados. Por favor intenta de nuevo.
      </div>
    )
  }

  {
    !fetchError && (
      <>
        <p class="text-sm text-gray-500 mb-6">
          {q ? (
            <>
              {total} resultado{total !== 1 ? "s" : ""} para{" "}
              <span class="font-medium text-gray-900">"{q}"</span>
            </>
          ) : (
            <>{total} producto{total !== 1 ? "s" : ""} disponibles</>
          )}
        </p>

        {listings.length === 0 ? (
          <div class="py-16 text-center">
            <p class="text-2xl font-semibold text-gray-700">Sin resultados</p>
            <p class="mt-2 text-gray-500">
              No encontramos productos para{" "}
              {q ? `"${q}"` : "esta búsqueda"}.
              Intenta con otro término.
            </p>
            <a
              href="/search"
              class="mt-6 inline-block rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
            >
              Ver todo el catálogo
            </a>
          </div>
        ) : (
          <>
            <!-- Listing grid -->
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
              {listings.map((listing) => (
                <a
                  href={`/listing/${listing.id}`}
                  class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:border-indigo-300 hover:shadow-md"
                >
                  {listing.image_url ? (
                    <img
                      src={listing.image_url}
                      alt={listing.name}
                      class="mb-3 h-36 w-full rounded-lg object-contain bg-gray-50"
                      loading="lazy"
                    />
                  ) : (
                    <div class="mb-3 flex h-36 w-full items-center justify-center rounded-lg bg-gray-100 text-gray-400 text-4xl">
                      &#9881;
                    </div>
                  )}

                  <p class="text-xs font-medium uppercase tracking-wide text-indigo-600">
                    {listing.store.name}
                  </p>
                  <h3 class="mt-1 line-clamp-2 text-sm font-semibold text-gray-900 group-hover:text-indigo-700">
                    {listing.name}
                  </h3>

                  <div class="mt-3 flex items-center justify-between">
                    {listing.price_cop !== null ? (
                      <span class="text-base font-bold text-gray-900">
                        ${listing.price_cop.toLocaleString("es-CO")} COP
                      </span>
                    ) : (
                      <span class="text-sm text-gray-400">Sin precio</span>
                    )}

                    {listing.stock_signal === "in_stock" && (
                      <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
                        Disponible
                      </span>
                    )}
                    {listing.stock_signal === "out_of_stock" && (
                      <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">
                        Agotado
                      </span>
                    )}
                    {listing.stock_signal === "unknown" && (
                      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">
                        Stock ?
                      </span>
                    )}
                  </div>

                  <p
                    class={`mt-2 text-xs ${
                      isStale(listing.last_scraped_at)
                        ? "text-amber-600"
                        : "text-gray-400"
                    }`}
                  >
                    Precio actualizado {timeSince(listing.last_scraped_at)}
                  </p>
                </a>
              ))}
            </div>

            <!-- Pagination -->
            {totalPages > 1 && (
              <nav class="mt-10 flex items-center justify-center gap-2">
                {page > 1 && (
                  <a
                    href={buildPageUrl(page - 1)}
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50"
                  >
                    &larr; Anterior
                  </a>
                )}
                {Array.from({ length: totalPages }, (_, i) => i + 1)
                  .filter(
                    (p) =>
                      p === 1 || p === totalPages || Math.abs(p - page) <= 2
                  )
                  .map((p, idx, arr) => (
                    <>
                      {idx > 0 && arr[idx - 1] !== p - 1 && (
                        <span class="px-1 text-gray-400">...</span>
                      )}
                      <a
                        href={buildPageUrl(p)}
                        class={`rounded-lg border px-3 py-2 text-sm ${
                          p === page
                            ? "border-indigo-600 bg-indigo-600 text-white"
                            : "border-gray-300 text-gray-600 hover:bg-gray-50"
                        }`}
                      >
                        {p}
                      </a>
                    </>
                  ))}
                {page < totalPages && (
                  <a
                    href={buildPageUrl(page + 1)}
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50"
                  >
                    Siguiente &rarr;
                  </a>
                )}
              </nav>
            )}
          </>
        )}
      </>
    )
  }
</Layout>
