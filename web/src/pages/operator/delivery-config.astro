---
// Operator delivery config page — SSR, requires session cookie.
export const prerender = false;

const API_URL =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ??
  "http://localhost:8080";

const sessionCookie = Astro.cookies.get("session")?.value;
if (!sessionCookie) {
  return Astro.redirect("/operator/login");
}

let config: any = null;
let fetchError = "";

try {
  const res = await fetch(`${API_URL}/v1/operator/delivery-config`, {
    headers: { Cookie: `session=${sessionCookie}` },
  });

  if (res.status === 401) {
    return Astro.redirect("/operator/login");
  }

  if (!res.ok) {
    fetchError = "Error al cargar configuración.";
  } else {
    config = await res.json();
  }
} catch (e) {
  fetchError = "Error de conexión con el servidor.";
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Configuración de domicilios — Protou Operador</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="bg-indigo-700 text-white px-6 py-3 flex items-center justify-between">
      <span class="text-xl font-bold">Protou — Operador</span>
      <nav class="flex gap-4 text-sm">
        <a href="/operator" class="hover:underline">Órdenes</a>
        <a href="/operator/couriers" class="hover:underline">Mensajeros</a>
        <a href="/operator/delivery-config" class="hover:underline font-semibold">Tarifas</a>
        <button id="logout-btn" class="hover:underline text-red-200">Cerrar sesión</button>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-6">
      <h1 class="text-2xl font-bold mb-6">Configuración de domicilios</h1>

      {fetchError && (
        <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700">{fetchError}</div>
      )}

      {config && (
        <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-6">
          <!-- Multi-store discount -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Descuento multi-tienda (%)
            </label>
            <input
              id="discount-pct"
              type="number"
              min="0"
              max="100"
              value={config.multi_store_discount_pct}
              class="rounded-lg border border-gray-300 px-3 py-2 text-sm w-24"
            />
            <p class="text-xs text-gray-500 mt-1">Se aplica cuando el pedido incluye productos de múltiples tiendas.</p>
          </div>

          <!-- Brackets table -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-semibold text-gray-700">Tarifas por distancia</h2>
              <button
                id="add-bracket-btn"
                class="rounded-lg border border-indigo-300 px-3 py-1 text-xs font-medium text-indigo-600 hover:bg-indigo-50"
              >
                + Agregar rango
              </button>
            </div>

            <div class="overflow-hidden rounded-lg border border-gray-200">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
                  <tr>
                    <th class="px-4 py-2 text-left">Desde (km)</th>
                    <th class="px-4 py-2 text-left">Hasta (km)</th>
                    <th class="px-4 py-2 text-left">Tarifa (COP)</th>
                    <th class="px-4 py-2"></th>
                  </tr>
                </thead>
                <tbody id="brackets-body" class="divide-y divide-gray-100">
                  {config.brackets.map((b: any, idx: number) => (
                    <tr class="bracket-row" data-idx={idx}>
                      <td class="px-4 py-2">
                        <input
                          type="number"
                          step="0.01"
                          min="0"
                          value={b.distance_km_min}
                          class="bracket-min w-24 rounded border border-gray-300 px-2 py-1 text-xs"
                        />
                      </td>
                      <td class="px-4 py-2">
                        <input
                          type="number"
                          step="0.01"
                          min="0"
                          value={b.distance_km_max ?? ""}
                          placeholder="∞"
                          class="bracket-max w-24 rounded border border-gray-300 px-2 py-1 text-xs"
                        />
                      </td>
                      <td class="px-4 py-2">
                        <input
                          type="number"
                          min="1"
                          value={b.fee_cop}
                          class="bracket-fee w-28 rounded border border-gray-300 px-2 py-1 text-xs"
                        />
                      </td>
                      <td class="px-4 py-2 text-right">
                        <button class="remove-bracket-btn text-xs text-red-500 hover:underline">
                          Eliminar
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <button
              id="save-btn"
              class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700 disabled:opacity-60"
            >
              Guardar configuración
            </button>
            <p id="save-msg" class="hidden text-sm"></p>
          </div>
        </div>
      )}
    </main>
  </body>
</html>

<script define:vars={{ API_URL }}>
  function showSaveMsg(msg, isError = false) {
    const el = document.getElementById("save-msg");
    el.textContent = msg;
    el.className = `text-sm ${isError ? "text-red-600" : "text-green-700"}`;
    el.classList.remove("hidden");
    setTimeout(() => el.classList.add("hidden"), 3000);
  }

  // Add bracket row
  document.getElementById("add-bracket-btn")?.addEventListener("click", () => {
    const tbody = document.getElementById("brackets-body");
    const tr = document.createElement("tr");
    tr.className = "bracket-row";
    tr.innerHTML = `
      <td class="px-4 py-2"><input type="number" step="0.01" min="0" value="0" class="bracket-min w-24 rounded border border-gray-300 px-2 py-1 text-xs" /></td>
      <td class="px-4 py-2"><input type="number" step="0.01" min="0" value="" placeholder="∞" class="bracket-max w-24 rounded border border-gray-300 px-2 py-1 text-xs" /></td>
      <td class="px-4 py-2"><input type="number" min="1" value="5000" class="bracket-fee w-28 rounded border border-gray-300 px-2 py-1 text-xs" /></td>
      <td class="px-4 py-2 text-right"><button class="remove-bracket-btn text-xs text-red-500 hover:underline">Eliminar</button></td>
    `;
    tbody.appendChild(tr);
    bindRemoveButtons();
  });

  function bindRemoveButtons() {
    document.querySelectorAll(".remove-bracket-btn").forEach((btn) => {
      btn.onclick = (e) => e.currentTarget.closest("tr").remove();
    });
  }
  bindRemoveButtons();

  // Save
  document.getElementById("save-btn")?.addEventListener("click", async (e) => {
    const discountPct = parseInt(document.getElementById("discount-pct").value, 10);
    const rows = document.querySelectorAll(".bracket-row");
    const brackets = [];
    let valid = true;

    rows.forEach((row) => {
      const min = parseFloat(row.querySelector(".bracket-min").value);
      const maxRaw = row.querySelector(".bracket-max").value;
      const max = maxRaw ? parseFloat(maxRaw) : null;
      const fee = parseInt(row.querySelector(".bracket-fee").value, 10);
      if (isNaN(min) || isNaN(fee) || fee <= 0) { valid = false; return; }
      brackets.push({ distance_km_min: min, distance_km_max: max, fee_cop: fee });
    });

    if (!valid) { showSaveMsg("Verifica que todas las tarifas sean > 0.", true); return; }

    const btn = e.currentTarget;
    btn.disabled = true;

    const res = await fetch(`${API_URL}/v1/operator/delivery-config`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ brackets, multi_store_discount_pct: discountPct }),
    });

    if (res.ok) {
      showSaveMsg("Configuración guardada correctamente.");
    } else {
      const d = await res.json();
      showSaveMsg(d.error ?? "Error al guardar.", true);
    }
    btn.disabled = false;
  });

  document.getElementById("logout-btn")?.addEventListener("click", async () => {
    await fetch(`${API_URL}/v1/operator/auth/logout`, { method: "POST", credentials: "include" });
    window.location.href = "/operator/login";
  });
</script>
