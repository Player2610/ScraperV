---
import Layout from "@/layouts/Layout.astro";
import { searchListings, getCategories } from "@/lib/api";
import type { Listing, Category } from "@/lib/api";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/search");

const url = Astro.url;
const pageParam = parseInt(url.searchParams.get("page") ?? "1", 10);
const page = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const perPage = 20;

let listings: Listing[] = [];
let total = 0;
let category: Category | null = null;
let subcategories: Category[] = [];
let notFound = false;
let fetchError = false;

try {
  // Resolve category from the categories tree
  const catsRes = await getCategories();
  const allCats = catsRes.categories;

  // Find this category in the flat list
  const flat: Category[] = [];
  function flatten(cats: Category[]) {
    for (const c of cats) {
      flat.push(c);
      if ((c as any).children) flatten((c as any).children);
    }
  }
  flatten(allCats);

  category = flat.find((c) => c.slug === slug) ?? null;

  if (!category) {
    notFound = true;
  } else {
    // Find direct children (subcategories)
    subcategories = flat.filter((c) => c.parent_id === category!.id);

    // Fetch listings for this category
    const qs = new URLSearchParams({ category: String(category.id), page: String(page), per_page: String(perPage) });
    // We use searchListings with numeric category id via direct fetch
    const listRes = await fetch(
      `${import.meta.env.PUBLIC_API_URL ?? "http://localhost:8080"}/v1/categories/${slug}/listings?page=${page}&per_page=${perPage}`
    );
    if (!listRes.ok) {
      if (listRes.status === 404) {
        notFound = true;
      } else {
        fetchError = true;
      }
    } else {
      const data = await listRes.json();
      listings = data.listings ?? [];
      total = data.total ?? 0;
    }
  }
} catch {
  fetchError = true;
}

if (notFound) {
  return new Response(null, { status: 404 });
}

const totalPages = Math.ceil(total / perPage);

function buildPageUrl(p: number): string {
  return `/categories/${slug}?page=${p}`;
}

function timeSince(isoDate: string | null): string {
  if (!isoDate) return "hace un tiempo";
  const diff = Date.now() - new Date(isoDate).getTime();
  const hours = Math.floor(diff / 3_600_000);
  if (hours < 1) return "hace < 1 hora";
  if (hours < 24) return `hace ${hours}h`;
  return `hace ${Math.floor(hours / 24)}d`;
}

function isStale(isoDate: string | null): boolean {
  if (!isoDate) return false;
  return Date.now() - new Date(isoDate).getTime() > 24 * 3_600_000;
}
---

<Layout title={category?.name ?? slug}>
  <!-- Breadcrumb -->
  <nav class="mb-6 text-sm text-gray-500">
    <ol class="flex items-center gap-1">
      <li><a href="/" class="hover:text-indigo-600">Inicio</a></li>
      <li>/</li>
      <li class="font-medium text-gray-900">{category?.name ?? slug}</li>
    </ol>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">{category?.name ?? slug}</h1>
    <p class="mt-2 text-sm text-gray-500">
      {total} producto{total !== 1 ? "s" : ""}
    </p>
  </div>

  {fetchError && (
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700 mb-6">
      Error al cargar los productos. Por favor intenta de nuevo.
    </div>
  )}

  <!-- Subcategory links -->
  {subcategories.length > 0 && (
    <div class="mb-8 flex flex-wrap gap-2">
      {subcategories.map((sub) => (
        <a
          href={`/categories/${sub.slug}`}
          class="rounded-full border border-gray-300 px-3 py-1 text-sm text-gray-600 hover:border-indigo-400 hover:text-indigo-600 transition"
        >
          {sub.name}
        </a>
      ))}
    </div>
  )}

  {!fetchError && listings.length === 0 && (
    <div class="py-16 text-center">
      <p class="text-xl font-semibold text-gray-700">Sin productos en esta categoría</p>
      <p class="mt-2 text-gray-500">Los productos estarán disponibles próximamente.</p>
      <a href="/search" class="mt-6 inline-block rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
        Ver todo el catálogo
      </a>
    </div>
  )}

  {!fetchError && listings.length > 0 && (
    <>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {listings.map((listing: Listing) => (
          <a
            href={`/listing/${listing.id}`}
            class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:border-indigo-300 hover:shadow-md"
          >
            {listing.image_url ? (
              <img
                src={listing.image_url}
                alt={listing.name}
                class="mb-3 h-36 w-full rounded-lg object-contain bg-gray-50"
                loading="lazy"
              />
            ) : (
              <div class="mb-3 flex h-36 w-full items-center justify-center rounded-lg bg-gray-100 text-gray-400 text-4xl">
                &#9881;
              </div>
            )}

            <p class="text-xs font-medium uppercase tracking-wide text-indigo-600">
              {listing.store.name}
            </p>
            <h3 class="mt-1 line-clamp-2 text-sm font-semibold text-gray-900 group-hover:text-indigo-700">
              {listing.name}
            </h3>

            <div class="mt-3 flex items-center justify-between">
              {listing.price_cop !== null ? (
                <span class="text-base font-bold text-gray-900">
                  ${listing.price_cop.toLocaleString("es-CO")} COP
                </span>
              ) : (
                <span class="text-sm text-gray-400">Sin precio</span>
              )}

              {listing.stock_signal === "in_stock" && (
                <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
                  Disponible
                </span>
              )}
              {listing.stock_signal === "out_of_stock" && (
                <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">
                  Agotado
                </span>
              )}
              {listing.stock_signal === "unknown" && (
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">
                  Stock ?
                </span>
              )}
            </div>

            <p class={`mt-2 text-xs ${isStale(listing.last_scraped_at) ? "text-amber-600" : "text-gray-400"}`}>
              {timeSince(listing.last_scraped_at)}
            </p>
          </a>
        ))}
      </div>

      <!-- Pagination -->
      {totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-center gap-2">
          {page > 1 && (
            <a href={buildPageUrl(page - 1)} class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">
              &larr; Anterior
            </a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1)
            .filter((p) => p === 1 || p === totalPages || Math.abs(p - page) <= 2)
            .map((p, idx, arr) => (
              <>
                {idx > 0 && arr[idx - 1] !== p - 1 && <span class="px-1 text-gray-400">...</span>}
                <a
                  href={buildPageUrl(p)}
                  class={`rounded-lg border px-3 py-2 text-sm ${p === page ? "border-indigo-600 bg-indigo-600 text-white" : "border-gray-300 text-gray-600 hover:bg-gray-50"}`}
                >
                  {p}
                </a>
              </>
            ))}
          {page < totalPages && (
            <a href={buildPageUrl(page + 1)} class="rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-600 hover:bg-gray-50">
              Siguiente &rarr;
            </a>
          )}
        </nav>
      )}
    </>
  )}
</Layout>
