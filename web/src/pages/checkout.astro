---
import Layout from "@/layouts/Layout.astro";

const API_URL =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ??
  "http://localhost:8080";
---

<Layout title="Checkout">
  <div class="mx-auto max-w-2xl" id="checkout-root">
    <h1 class="text-2xl font-bold text-gray-900">Checkout</h1>

    <!-- Step indicator -->
    <ol id="step-indicator" class="mt-4 flex gap-4 text-sm font-medium">
      <li id="step-indicator-1" class="text-indigo-600">1. Dirección</li>
      <li id="step-indicator-2" class="text-gray-400">2. Pago</li>
      <li id="step-indicator-3" class="text-gray-400">3. Confirmar</li>
    </ol>

    <!-- Step 1: Address -->
    <section id="step-1" class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900">Dirección de entrega</h2>

      <div id="addresses-loading" class="mt-4 text-sm text-gray-500">Cargando direcciones...</div>

      <div id="addresses-container" class="mt-4 hidden space-y-3">
        <!-- Populated by JS -->
      </div>

      <!-- New address form -->
      <div id="new-address-form" class="mt-4 space-y-3 hidden">
        <div>
          <label for="new-full-address" class="block text-sm font-medium text-gray-700">
            Dirección completa
          </label>
          <input
            id="new-full-address"
            type="text"
            placeholder="Ej: Cra 7 #45-20, Bogotá"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
          />
        </div>
        <div>
          <label for="new-reference" class="block text-sm font-medium text-gray-700">
            Referencia <span class="text-gray-400">(opcional)</span>
          </label>
          <input
            id="new-reference"
            type="text"
            placeholder="Ej: Edificio azul, piso 3"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
          />
        </div>
      </div>

      <p id="address-error" class="mt-2 hidden text-sm text-red-600"></p>
      <p id="zone-error" class="mt-2 hidden rounded-md bg-red-50 px-3 py-2 text-sm text-red-700">
        Esta dirección está fuera de la zona de cobertura (Bogotá y Soacha).
      </p>

      <!-- Fee preview -->
      <div id="fee-preview" class="mt-4 hidden rounded-lg bg-indigo-50 px-4 py-3">
        <p class="text-sm text-indigo-800">
          Domicilio estimado:
          <span id="fee-amount" class="font-semibold"></span>
        </p>
        <p id="fee-breakdown" class="mt-0.5 text-xs text-indigo-600"></p>
      </div>

      <button
        id="step1-next"
        class="mt-6 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-indigo-700 disabled:opacity-60"
        disabled
      >
        Continuar
      </button>
    </section>

    <!-- Step 2: Payment -->
    <section id="step-2" class="mt-8 hidden">
      <h2 class="text-lg font-semibold text-gray-900">Método de pago</h2>
      <p class="mt-1 text-sm text-gray-500">Pagarás al recibir tu pedido.</p>

      <div class="mt-4 space-y-3">
        {[
          { value: "nequi", label: "Nequi", icon: "📲" },
          { value: "daviplata", label: "Daviplata", icon: "📱" },
          { value: "efectivo", label: "Efectivo", icon: "💵" },
          { value: "llaves_breve", label: "Llaves Breve", icon: "🔑" },
        ].map((opt) => (
          <label class="payment-option flex cursor-pointer items-center gap-3 rounded-xl border border-gray-200 p-4 hover:border-indigo-400 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
            <input
              type="radio"
              name="payment_method"
              value={opt.value}
              class="h-4 w-4 text-indigo-600"
            />
            <span class="text-lg">{opt.icon}</span>
            <span class="text-sm font-medium text-gray-900">{opt.label}</span>
          </label>
        ))}
      </div>

      <div class="mt-4">
        <label for="notes" class="block text-sm font-medium text-gray-700">
          Notas para el pedido <span class="text-gray-400">(opcional)</span>
        </label>
        <textarea
          id="notes"
          rows="2"
          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
          placeholder="Ej: Llama al portero..."
        ></textarea>
      </div>

      <div class="mt-6 flex gap-3">
        <button
          id="step2-back"
          class="rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50"
        >
          Atrás
        </button>
        <button
          id="step2-next"
          class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-indigo-700 disabled:opacity-60"
          disabled
        >
          Continuar
        </button>
      </div>
    </section>

    <!-- Step 3: Summary + Confirm -->
    <section id="step-3" class="mt-8 hidden">
      <h2 class="text-lg font-semibold text-gray-900">Resumen del pedido</h2>

      <!-- Items -->
      <div id="summary-items" class="mt-4 space-y-2 text-sm text-gray-700">
        <!-- Populated by JS from cart data -->
      </div>

      <!-- Totals -->
      <div class="mt-4 space-y-1 border-t border-gray-200 pt-4 text-sm">
        <div class="flex justify-between text-gray-600">
          <span>Subtotal</span>
          <span id="summary-subtotal">—</span>
        </div>
        <div class="flex justify-between text-gray-600">
          <span>Domicilio</span>
          <span id="summary-fee">—</span>
        </div>
        <div class="flex justify-between font-semibold text-gray-900">
          <span>Total</span>
          <span id="summary-total">—</span>
        </div>
      </div>

      <!-- Address & payment recap -->
      <div class="mt-4 space-y-1 rounded-lg bg-gray-50 px-4 py-3 text-sm text-gray-600">
        <p><span class="font-medium">Dirección:</span> <span id="summary-address">—</span></p>
        <p><span class="font-medium">Pago:</span> <span id="summary-payment">—</span></p>
      </div>

      <!-- Submit error -->
      <p id="submit-error" class="mt-3 hidden rounded-md bg-red-50 px-3 py-2 text-sm text-red-700"></p>

      <div class="mt-6 flex gap-3">
        <button
          id="step3-back"
          class="rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50"
        >
          Atrás
        </button>
        <button
          id="confirm-btn"
          class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-indigo-700 disabled:opacity-60"
        >
          Confirmar pedido
        </button>
      </div>
    </section>

    <!-- Step 4: Success -->
    <section id="step-success" class="mt-16 hidden text-center">
      <div class="text-5xl">✅</div>
      <h2 class="mt-4 text-2xl font-bold text-gray-900">¡Pedido recibido!</h2>
      <p class="mt-2 text-gray-600">
        Tu pedido <span id="success-order-id" class="font-semibold text-indigo-600"></span> fue
        creado exitosamente.
      </p>
      <p class="mt-1 text-sm text-gray-500">
        Nuestro equipo lo revisará y te notificará cuando esté confirmado.
      </p>
      <div class="mt-6 flex justify-center gap-4">
        <a
          id="view-order-link"
          href="/orders"
          class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700"
        >
          Ver mi pedido
        </a>
        <a
          href="/search"
          class="rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50"
        >
          Seguir comprando
        </a>
      </div>
    </section>
  </div>
</Layout>

<script define:vars={{ API_URL }}>
  const token =
    localStorage.getItem("protou_token") ||
    document.cookie.split("; ").find((r) => r.startsWith("protou_token="))?.split("=")[1];

  if (!token) {
    window.location.href = "/login?redirect=/checkout";
  }

  const PAYMENT_LABELS = {
    nequi: "Nequi",
    daviplata: "Daviplata",
    efectivo: "Efectivo",
    llaves_breve: "Llaves Breve",
  };

  // State
  let state = {
    step: 1,
    addresses: [],
    selectedAddressId: null,
    newAddressMode: false,
    feeResult: null,
    cartItems: [],
    paymentMethod: null,
    notes: "",
  };

  // DOM refs
  const $ = (id) => document.getElementById(id);

  function formatCOP(v) {
    return "$" + (v ?? 0).toLocaleString("es-CO") + " COP";
  }

  function goToStep(n) {
    [1, 2, 3].forEach((i) => {
      $(`step-${i}`)?.classList.toggle("hidden", i !== n);
      const ind = $(`step-indicator-${i}`);
      if (ind) {
        ind.className = i === n ? "text-indigo-600 font-semibold" : i < n ? "text-gray-700" : "text-gray-400";
      }
    });
    state.step = n;
  }

  async function init() {
    if (!token) return;

    // Load addresses and cart in parallel
    const [addrRes, cartRes] = await Promise.all([
      fetch(`${API_URL}/v1/users/me/addresses`, {
        headers: { Authorization: `Bearer ${token}` },
      }),
      fetch(`${API_URL}/v1/cart`, {
        headers: { Authorization: `Bearer ${token}` },
      }),
    ]);

    if (addrRes.status === 401 || cartRes.status === 401) {
      window.location.href = "/login?redirect=/checkout";
      return;
    }

    const addrData = addrRes.ok ? await addrRes.json() : { addresses: [] };
    const cartData = cartRes.ok ? await cartRes.json() : { items: [] };

    state.addresses = addrData.addresses ?? [];
    state.cartItems = cartData.items ?? [];

    renderAddresses();
    $("addresses-loading")?.classList.add("hidden");
  }

  function renderAddresses() {
    const container = $("addresses-container");
    if (!container) return;
    container.innerHTML = "";
    container.classList.remove("hidden");

    state.addresses.forEach((addr) => {
      const div = document.createElement("label");
      div.className =
        "address-option flex cursor-pointer items-start gap-3 rounded-xl border border-gray-200 p-4 hover:border-indigo-400 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50";
      div.innerHTML = `
        <input type="radio" name="address" value="${addr.id}" class="mt-0.5 h-4 w-4 text-indigo-600" />
        <div>
          <p class="text-sm font-medium text-gray-900">${addr.label ?? addr.full_address}</p>
          ${addr.label ? `<p class="text-xs text-gray-500">${addr.full_address}</p>` : ""}
          ${addr.reference ? `<p class="text-xs text-gray-400">${addr.reference}</p>` : ""}
        </div>
      `;
      container.appendChild(div);
    });

    // New address option
    const newDiv = document.createElement("label");
    newDiv.className =
      "flex cursor-pointer items-center gap-3 rounded-xl border border-gray-200 p-4 hover:border-indigo-400 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50";
    newDiv.innerHTML = `
      <input type="radio" name="address" value="new" class="h-4 w-4 text-indigo-600" />
      <span class="text-sm font-medium text-gray-700">+ Nueva dirección</span>
    `;
    container.appendChild(newDiv);

    // Listen for address selection
    container.addEventListener("change", async (e) => {
      if (e.target.name !== "address") return;
      $("zone-error")?.classList.add("hidden");
      $("address-error")?.classList.add("hidden");
      $("fee-preview")?.classList.add("hidden");
      $("step1-next").disabled = true;

      if (e.target.value === "new") {
        state.selectedAddressId = null;
        state.newAddressMode = true;
        $("new-address-form")?.classList.remove("hidden");
        $("step1-next").disabled = false;
        return;
      }

      state.newAddressMode = false;
      $("new-address-form")?.classList.add("hidden");

      const addrId = parseInt(e.target.value, 10);
      state.selectedAddressId = addrId;
      await fetchFeePreview(addrId);
    });
  }

  async function fetchFeePreview(addressId) {
    $("fee-preview")?.classList.add("hidden");
    $("zone-error")?.classList.add("hidden");
    $("step1-next").disabled = true;

    try {
      const res = await fetch(`${API_URL}/v1/checkout/delivery-fee`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ address_id: addressId }),
      });

      const data = await res.json();

      if (!res.ok) {
        if (data.code === "OUTSIDE_ZONE") {
          $("zone-error")?.classList.remove("hidden");
        } else {
          $("address-error").textContent = data.error ?? "Error al calcular domicilio.";
          $("address-error")?.classList.remove("hidden");
        }
        return;
      }

      state.feeResult = data;
      $("fee-amount").textContent = formatCOP(data.total_fee);
      $("fee-breakdown").textContent = data.breakdown ?? "";
      $("fee-preview")?.classList.remove("hidden");
      $("step1-next").disabled = false;
    } catch {
      $("address-error").textContent = "Error de red al calcular domicilio.";
      $("address-error")?.classList.remove("hidden");
    }
  }

  // Step 1 Next
  $("step1-next")?.addEventListener("click", async () => {
    if (state.newAddressMode) {
      const fullAddress = $("new-full-address")?.value.trim();
      if (!fullAddress) {
        $("address-error").textContent = "La dirección es requerida.";
        $("address-error")?.classList.remove("hidden");
        return;
      }

      // Save address first
      try {
        const reference = $("new-reference")?.value.trim() || undefined;
        const res = await fetch(`${API_URL}/v1/users/me/addresses`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ full_address: fullAddress, reference }),
        });
        if (!res.ok) {
          $("address-error").textContent = "Error al guardar la dirección.";
          $("address-error")?.classList.remove("hidden");
          return;
        }
        const data = await res.json();
        state.selectedAddressId = data.address.id;
        state.addresses.push(data.address);
        await fetchFeePreview(data.address.id);
        if (state.feeResult) {
          goToStep(2);
        }
      } catch {
        $("address-error").textContent = "Error de red.";
        $("address-error")?.classList.remove("hidden");
      }
      return;
    }
    goToStep(2);
  });

  // Payment method selection
  document.querySelectorAll('input[name="payment_method"]').forEach((radio) => {
    radio.addEventListener("change", (e) => {
      state.paymentMethod = e.target.value;
      $("step2-next").disabled = false;
    });
  });

  // Notes
  $("notes")?.addEventListener("input", (e) => {
    state.notes = e.target.value;
  });

  // Step 2 Back/Next
  $("step2-back")?.addEventListener("click", () => goToStep(1));
  $("step2-next")?.addEventListener("click", () => {
    buildSummary();
    goToStep(3);
  });

  function buildSummary() {
    // Items
    const container = $("summary-items");
    if (container) {
      container.innerHTML = state.cartItems
        .filter((i) => !i.unavailable)
        .map(
          (i) =>
            `<div class="flex justify-between">
              <span>${i.listing?.name ?? `#${i.listing_id}`} × ${i.quantity}</span>
              <span>${i.listing?.price_cop ? formatCOP(i.listing.price_cop * i.quantity) : "—"}</span>
            </div>`
        )
        .join("");
    }

    const subtotal = state.cartItems
      .filter((i) => !i.unavailable && i.listing?.price_cop)
      .reduce((s, i) => s + i.listing.price_cop * i.quantity, 0);

    $("summary-subtotal").textContent = formatCOP(subtotal);
    $("summary-fee").textContent = formatCOP(state.feeResult?.total_fee ?? 0);
    $("summary-total").textContent = formatCOP(subtotal + (state.feeResult?.total_fee ?? 0));

    // Address
    const addr = state.addresses.find((a) => a.id === state.selectedAddressId);
    $("summary-address").textContent = addr?.full_address ?? "—";

    // Payment
    $("summary-payment").textContent = PAYMENT_LABELS[state.paymentMethod] ?? state.paymentMethod ?? "—";
  }

  // Step 3 Back/Confirm
  $("step3-back")?.addEventListener("click", () => goToStep(2));

  $("confirm-btn")?.addEventListener("click", async () => {
    $("submit-error")?.classList.add("hidden");
    $("confirm-btn").disabled = true;
    $("confirm-btn").textContent = "Procesando...";

    try {
      const body = {
        address_id: state.selectedAddressId,
        payment_method: state.paymentMethod,
      };
      if (state.notes) body.notes = state.notes;

      const res = await fetch(`${API_URL}/v1/orders`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (!res.ok) {
        let msg = data.error ?? "Error al crear el pedido.";
        if (data.code === "OUTSIDE_ZONE") msg = "La dirección está fuera de la zona de cobertura.";
        if (data.code === "EMPTY_CART") msg = "Tu carrito está vacío.";
        if (data.code === "UNAVAILABLE_ITEMS") msg = "Algunos productos no están disponibles.";
        $("submit-error").textContent = msg;
        $("submit-error")?.classList.remove("hidden");
        return;
      }

      const orderId = data.order?.id;
      $("success-order-id").textContent = `#${orderId}`;
      $("view-order-link").href = `/orders/${orderId}`;

      [1, 2, 3].forEach((i) => $(`step-${i}`)?.classList.add("hidden"));
      $("step-success")?.classList.remove("hidden");
    } catch {
      $("submit-error").textContent = "Error de red. Intenta de nuevo.";
      $("submit-error")?.classList.remove("hidden");
    } finally {
      $("confirm-btn").disabled = false;
      $("confirm-btn").textContent = "Confirmar pedido";
    }
  });

  // Initialize
  init();
</script>
