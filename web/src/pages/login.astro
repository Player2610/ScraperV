---
import Layout from "@/layouts/Layout.astro";

const API_URL =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ??
  "http://localhost:8080";
---

<Layout title="Iniciar sesión">
  <div class="mx-auto max-w-md">
    <h1 class="text-2xl font-bold text-gray-900">Iniciar sesión</h1>
    <p class="mt-2 text-sm text-gray-600">
      ¿No tienes cuenta?{" "}
      <a href="/register" class="text-indigo-600 hover:underline">Crear cuenta</a>
    </p>

    <form id="login-form" class="mt-8 space-y-5" novalidate>
      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700">
          Correo electrónico
        </label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
        />
        <p id="email-error" class="mt-1 hidden text-xs text-red-600"></p>
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700">
          Contraseña
        </label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-400"
        />
      </div>

      <!-- Global error (also used for invalid credentials) -->
      <p id="form-error" class="hidden rounded-md bg-red-50 px-3 py-2 text-sm text-red-700"></p>

      <button
        type="submit"
        id="submit-btn"
        class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-60"
      >
        Iniciar sesión
      </button>
    </form>
  </div>
</Layout>

<script define:vars={{ API_URL }}>
  const form = document.getElementById("login-form");
  const submitBtn = document.getElementById("submit-btn");
  const formError = document.getElementById("form-error");

  function clearError() {
    formError.textContent = "";
    formError.classList.add("hidden");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearError();

    const email = form.email.value.trim();
    const password = form.password.value;

    if (!email || !password) {
      formError.textContent = "Ingresa tu correo y contraseña.";
      formError.classList.remove("hidden");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Ingresando...";

    try {
      const res = await fetch(`${API_URL}/v1/auth/login`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        if (res.status === 401) {
          formError.textContent = "Credenciales inválidas";
        } else {
          formError.textContent = data.error ?? "Error al iniciar sesión. Intenta de nuevo.";
        }
        formError.classList.remove("hidden");
        return;
      }

      localStorage.setItem("protou_token", data.token);
      localStorage.setItem("protou_user", JSON.stringify(data.user));

      // Migrate guest cart if any
      const guestCart = localStorage.getItem("protou_guest_cart");
      if (guestCart) {
        try {
          const items = JSON.parse(guestCart);
          await fetch(`${API_URL}/v1/cart/migrate`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${data.token}`,
            },
            body: JSON.stringify({ items }),
          });
          localStorage.removeItem("protou_guest_cart");
        } catch {}
      }

      // Redirect to referrer or cart
      const params = new URLSearchParams(window.location.search);
      const redirectTo = params.get("redirect") ?? "/cart";
      window.location.href = redirectTo;
    } catch (err) {
      formError.textContent = "Error de red. Intenta de nuevo.";
      formError.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Iniciar sesión";
    }
  });
</script>
