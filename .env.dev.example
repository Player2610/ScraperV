# ─── Dev environment — copy to .env.dev and fill in PROD_DATABASE_URL ─────────
#
# DATABASE_URL  → local Docker container (read/write for dev)
# PROD_DATABASE_URL → Neon (READ ONLY — only the db-sync service touches this)
#
# NEVER write application code that uses PROD_DATABASE_URL.
# Data only flows: prod → dev. Never dev → prod.

# Local DB (Docker container — hostname localhost for host tools, db for containers)
DATABASE_URL=postgres://postgres:password@localhost:5432/protou?sslmode=disable

# Production Neon DB — source for sync (READ ONLY)
# Copy the value of DATABASE_URL from .env (the Neon connection string)
PROD_DATABASE_URL=postgresql://<user>:<pass>@<host>/<db>?sslmode=require

# JWT — any random 32+ char string works for dev
JWT_SECRET=dev-secret-min-32-characters-long-replace-me

# Resend — use your real key to test email flows in dev
RESEND_API_KEY=re_...

# Google Maps — leave blank if not testing geocoding
GOOGLE_MAPS_API_KEY=

# API port
PORT=8080

# Allow requests from Astro dev server
CORS_ORIGIN=http://localhost:4321

# Email From header — shows "protou DEV" so dev emails son distinguibles de prod
NOTIFICATIONS_FROM=protou DEV <pedidos+dev@protou.co>

# Scraper alert recipient — leave blank to disable scraper email alerts in dev
ALERT_EMAIL=
